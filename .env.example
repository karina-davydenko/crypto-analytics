# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=crypto_analytics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL для подключения FastAPI к PostgreSQL (через хост, не через Docker)
DATABASE_URL=postgresql://airflow:airflow@localhost:5433/crypto_analytics

# Airflow Fernet key — шифрует пароли в метаданных Airflow.
# Сгенерировать новый:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=замени_на_свой_ключ

# NewsAPI — получить бесплатный ключ на https://newsapi.org
NEWSAPI_KEY=замени_на_свой_ключ
